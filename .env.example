# Copy this file to .env and fill the values. Never commit .env.

# ---- Django ----
DJANGO_SECRET_KEY=__generate_with__ python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# ---- Postgres ----
POSTGRES_DB=tarot
POSTGRES_USER=tarot
POSTGRES_PASSWORD=tarot
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Anthropic ----
ANTHROPIC_API_KEY=__set_me__
ANTHROPIC_MODEL_FREE=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_PREMIUM=claude-sonnet-4-6
ANTHROPIC_MODEL_DEEP=claude-opus-4-7

# ---- Paddle (Merchant of Record) ----
# Get from https://vendors.paddle.com → Developer Tools → Authentication
PADDLE_ENV=sandbox
PADDLE_API_KEY=__set_me__
PADDLE_WEBHOOK_SECRET=__set_me__
PADDLE_CLIENT_TOKEN=__set_me__

# Paddle product / price IDs (Products → Prices tab in Paddle Dashboard)
PADDLE_PRODUCT_PREMIUM_MONTHLY=
PADDLE_PRICE_PREMIUM_MONTHLY=
PADDLE_PRODUCT_CREDITS_SMALL=
PADDLE_PRICE_CREDITS_SMALL=
PADDLE_PRODUCT_CREDITS_LARGE=
PADDLE_PRICE_CREDITS_LARGE=

# ---- Frontend ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=__get_from_google_cloud_console__

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=__same_as_NEXT_PUBLIC_GOOGLE_CLIENT_ID__

# ---- CORS (production only) ----
CORS_ALLOWED_ORIGINS=https://tarot.example.com
