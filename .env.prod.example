# ══════════════════════════════════════════════════════════════
#  PRODUCTION ENV — copy to .env.prod and fill every value
#  Never commit .env.prod to git!
# ══════════════════════════════════════════════════════════════

# ── Django ──────────────────────────────────────────────────
# Generate:  python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=__replace_me__
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=sokirdon.com,www.sokirdon.com
DJANGO_SETTINGS_MODULE=config.settings.prod

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=tarot
POSTGRES_USER=tarot
POSTGRES_PASSWORD=__strong_password__
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_FREE=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_PREMIUM=claude-sonnet-4-6
ANTHROPIC_MODEL_DEEP=claude-opus-4-7

# ── Paddle (get from vendors.paddle.com → Developer Tools) ───
# Start with sandbox=True, switch to production when ready
PADDLE_ENV=sandbox
PADDLE_API_KEY=__set_me__
PADDLE_WEBHOOK_SECRET=__set_me__
PADDLE_CLIENT_TOKEN=__set_me__

# Paddle product/price IDs  (Catalog → Products → Prices tab)
PADDLE_PRODUCT_PREMIUM_MONTHLY=
PADDLE_PRICE_PREMIUM_MONTHLY=
PADDLE_PRODUCT_CREDITS_SMALL=
PADDLE_PRICE_CREDITS_SMALL=
PADDLE_PRODUCT_CREDITS_LARGE=
PADDLE_PRICE_CREDITS_LARGE=

# ── CORS / CSRF ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://sokirdon.com
CSRF_TRUSTED_ORIGINS=https://sokirdon.com

# ── Frontend (baked into Next.js build) ─────────────────────
NEXT_PUBLIC_API_URL=https://sokirdon.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=__get_from_google_cloud_console__

# ── Google OAuth (backend verification) ─────────────────────
GOOGLE_CLIENT_ID=__same_as_NEXT_PUBLIC_GOOGLE_CLIENT_ID__

# ── Cloudflare Tunnel ────────────────────────────────────────
# Get from: Cloudflare Dashboard → Zero Trust → Networks → Tunnels
# Create tunnel → Docker → copy the token from the docker run command
CLOUDFLARE_TUNNEL_TOKEN=__paste_tunnel_token_here__
